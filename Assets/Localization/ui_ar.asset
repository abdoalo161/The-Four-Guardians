      m_Items: []
  - m_Id: 1989087970975744
    m_Localized: "\u0643\u0631\u0648\u062F \uFEF2\uFEEC\uFEE7\u0627 \uFEE2\uFE9B
      \u063A\u0631\uFE8E\uFED3 \u0631\uFE8E\uFEB4\uFEE3 \uFBFD\uFEDF\u0625 \uFE94\uFED7\uFE8E\uFEC4\uFE91
      \uFE90\uFEA4\uFEB3\u0627 . \u062A\uFE8E\uFED7\uFE8E\uFEC4\uFE91 \uFEF2\uFEE7\uFE8E\uFEE4\uFE9B
      \uFBFD\uFEDF\u0625 \u062F\uFEAA\uFECB \uFEDE\uFEBC\uFEF3 \uFBFD\uFE98\uFEA3
      \uFE94\uFED7\uFE8E\uFEC4\uFE91 \uFEE6\uFECB \u0651\uFEDE\uFEA8\uFE97 \u060C
      \u062A\uFE8E\uFED7\uFE8E\uFEC4\uFE91 \uFEF2\uFEE7\uFE8E\uFEE4\uFE9B \u0643\uFEAA\uFEF3
      \u062A\uFE8E\uFED7\uFE8E\uFEC4\uFE91 \u062F\uFEAA\uFECB \u0632\u0648\uFE8E\uFEA0\uFE97
      \u0627\u0630\u0625 . \uFEF2\uFE8B\uFE8E\uFED8\uFEE0\uFE97 \uFE90\uFEA4\uFEB4\uFEDF\u0627"
    m_Metadata:
      m_Items: []
  - m_Id: 1989146120806400
    m_Localized: ": \u0644\uFE8E\uFE98\uFED8\uFEDF\u0627"
    m_Metadata:
      m_Items: []
  - m_Id: 1989253830533120
    m_Localized: "\u0646\u0627\uFEB0\uFEF4\uFEE4\uFEDF\u0627 \uFBFD\uFEE0\uFECB \u0629\uFEAE\uFEB7\uFE8E\uFE92\uFEE3
      \u0641\uFE8E\uFEC0\uFE97 \u0631\uFEAE\uFEC0\uFEDF\u0627 \u0637\uFE8E\uFED8\uFEE7
      \u0646\uFE88\uFED3 \u063A\u0631\uFE8E\uFED3 \u0631\uFE8E\uFEB4\uFEE4\uFEDF\u0627
      \u0646\uFE8E\uFEDB \u0627\u0630\u0625 \uFEEA\uFEDF \uFEDE\uFE91\uFE8E\uFED8\uFEE4\uFEDF\u0627
      \u0631\uFE8E\uFEB4\uFEE4\uFEDF\u0627 \uFEE2\uFE9F\uFE8E\uFEEC\uFEF3 \u0631\uFE8E\uFEB4\uFEE3
      \uFEDE\uFEDB\r\n\uFEAE\uFEE3\uFEAA\uFE97 0 \uFBFD\uFEDF\u0625 \uFE8E\uFEEC\uFE98\uFEA4\uFEBB
      \u0637\uFE8E\uFED8\uFEE7 \uFEDE\uFEBC\uFE97 \uFEF2\uFE98\uFEDF\u0627 \u062A\uFE8E\uFED7\uFE8E\uFEC4\uFE92\uFEDF\u0627\u0648
      \uFE94\uFED7\uFE8E\uFEC4\uFE92\uFEDF\u0627 \u0628 \uFED6\uFEA4\uFEE0\uFEF3
      \u0631\uFEAE\uFEC0\uFEDF\u0627 \u0646\uFE88\uFED3 \u063A\u0631\uFE8E\uFED3
      \u0631\uFE8E\uFEB4\uFEE4\uFEDF\u0627 \uFEE6\uFEDC\uFEF3 \uFEE2\uFEDF \u0646\u0625\u0648\r\n"
    m_Metadata:
      m_Items: []
  - m_Id: 1989271815708672
    m_Localized: ": \uFEAE\uFEBB\uFE8E\uFEE8\uFECC\uFEDF\u0627 "
    m_Metadata:
      m_Items: []
  - m_Id: 1989333388091392
