    m_Metadata:
      m_Items: []
  - m_Id: 1990050744098816
    m_Localized: "\r.\uFEDA\uFEA4\uFEDF\uFE8E\uFEBB \uFEF2\uFED3 \u0646\u0627\uFEB0\uFEF4\uFEE4\uFEDF\u0627
      \u0651\u0646\u0623 \uFEF2\uFEE8\uFECC\uFEF3 \u0627\uFEAC\uFEEC\uFED3 \uFEAE\uFED4\uFEBB\uFEF7\u0627
      \u0646\uFEEE\uFEE0\uFEDF\uFE8E\uFE91 \uFEE2\uFED7\uFEAE\uFEDF\u0627 \u0646\uFE8E\uFEDB
      \u0627\u0630\u0625\r\n\r.\u0629\u0631\uFE8E\uFEB4\uFEA8\uFEDF\u0627 \uFECA\uFEBF\u0648
      \uFEF2\uFED3 \uFEDA\u0651\uFEE7\u0623 \uFEF2\uFEE8\uFECC\uFEF3 \u0627\uFEAC\uFEEC\uFED3
      \u0642\u0631\u0632\uFEF7\u0627 \u0646\uFEEE\uFEE0\uFEDF\uFE8E\uFE91 \u0646\uFE8E\uFEDB
      \u0627\u0630\u0625\u0648\r\n\r.\u0629\u0627\u0631\uFE8E\uFE92\uFEE4\uFEDF\uFE8E\uFE91
      \u0632\uFEEE\uFED4\uFEF3 \uFEEA\uFEA4\uFEDF\uFE8E\uFEBB \uFEF2\uFED3 20 \uFE94\uFEE4\uFEF4\uFED7
      \uFBFD\uFEDF\u0625 \uFEDE\uFEBC\uFEF3 \u0646\u0627\uFEB0\uFEF4\uFEE4\uFEDF\u0627
      \uFEDE\uFECC\uFEA0\uFEF3 \uFE90\uFECB\uFEFB \u0644\u0651\u0648\u0623\r\n\r.\uFEE2\uFEBC\uFEA8\uFEDF\u0627
      \uFEDE\u0651\uFE9C\uFEE4\uFE97 \u0649\uFEAE\uFEB4\uFEF4\uFEDF\u0627 \uFE94\uFEEC\uFEA0\uFEDF\u0627\u0648
      \u060C\uFE96\uFEE7\u0623 \uFEDA\uFEE0\u0651\uFE9C\uFEE4\uFE97 \u0646\u0627\uFEB0\uFEF4\uFEE4\uFEDF\u0627
